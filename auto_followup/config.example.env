# Copy to .env and fill in

# Required
EMAIL_USERNAME="you@example.com"
EMAIL_PASSWORD="your_app_password_here"
FROM_EMAIL="you@example.com"

# Optional display name
FROM_NAME="Your Name"

# SMTP (outgoing)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_STARTTLS="true"

# IMAP (incoming)
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
# For Gmail use [Gmail]/Sent Mail, Outlook often uses Sent Items
IMAP_SENT_FOLDER="[Gmail]/Sent Mail"

# Behavior
TRACK_SUBJECT_TOKEN="[FU]"
FOLLOWUP_AFTER_DAYS="3"
MAX_FOLLOWUPS_PER_THREAD="1"

# Paths
SQLITE_DB_PATH="./auto_followup.sqlite3"
TEMPLATE_PATH="./templates/followup.txt"

# Misc
TIMEZONE="UTC"
DRY_RUN="true"